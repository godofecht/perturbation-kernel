# Copy to .env and adjust. All paths may be absolute or relative to app/server.

# Port the API + WebSocket listen on.
PORT=8088

# The Lean project whose Mathlib environment the REPL loads, and whose files
# are browsable in the app. Defaults to the repo's lean/PerturbationKernel.
LEAN_PROJECT_DIR=../../lean/PerturbationKernel

# How to launch the Lean REPL inside that project. The default assumes you have
# cloned and built https://github.com/leanprover-community/repl and exported
# REPL_BIN to its built binary, e.g.
#   REPL_BIN=/path/to/repl/.lake/build/bin/repl
# The server then runs:  lake env "$REPL_BIN"   (cwd = LEAN_PROJECT_DIR)
# Leave REPL_BIN unset to run the app in visualise-only mode (no live runs).
# REPL_BIN=

# Max seconds to wait for a single typecheck before giving up.
RUN_TIMEOUT_SECONDS=120
